generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  GUEST
  FAMILY
  ADMIN
  MODERATOR
}

enum CaseStatus {
  ACTIVE
  FOUND
  ARCHIVED
}

enum TipStatus {
  NEW
  UNDER_REVIEW
  VERIFIED
  DISMISSED
  ESCALATED
}

enum LeadSource {
  FACEBOOK
  INSTAGRAM
  X
  WEB
  MANUAL
}

enum ReviewDecision {
  APPROVED
  REJECTED
  NEEDS_MORE_INFO
}

enum PrivacyLevel {
  PUBLIC
  LIMITED
  PRIVATE
}

enum LeadStatus {
  NEW
  UNDER_REVIEW
  APPROVED
  REJECTED
  ESCALATED
}

enum NotificationType {
  TIP
  LEAD
  STATUS
  SYSTEM
}

model User {
  id             String         @id @default(cuid())
  name           String
  email          String         @unique
  passwordHash   String?
  role           UserRole       @default(FAMILY)
  title          String?
  organizationId String?
  organization   Organization?  @relation(fields: [organizationId], references: [id])
  profile        Profile?
  ownedCases     Case[]         @relation("CaseOwner")
  submittedTips  Tip[]          @relation("TipReporter")
  reviews        Review[]
  auditLogs      AuditLog[]     @relation("AuditActor")
  notifications  Notification[]
  caseUpdates    CaseUpdate[]   @relation("CaseUpdateAuthor")
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@index([role])
  @@index([organizationId])
}

model Profile {
  id          String   @id @default(cuid())
  userId      String   @unique
  phone       String?
  avatarUrl   String?
  city        String?
  country     String?
  notifyEmail Boolean  @default(true)
  notifyInApp Boolean  @default(true)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique
  contactEmail String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  users        User[]
  cases        Case[]
}

model Location {
  id             String          @id @default(cuid())
  label          String
  address        String?
  city           String
  county         String?
  country        String
  latitude       Float
  longitude      Float
  lastSeenCases  Case[]          @relation("CaseLastSeenLocation")
  tipSightings   Tip[]           @relation("TipLocation")
  leadSightings  Lead[]          @relation("LeadLocation")
  monitoringHits MonitoringHit[] @relation("MonitoringLocation")

  @@index([city, country])
  @@index([latitude, longitude])
}

model Case {
  id                     String         @id @default(cuid())
  slug                   String         @unique
  fullName               String
  nickname               String?
  age                    Int
  gender                 String
  lastSeenAt             DateTime
  lastSeenLocationId     String
  lastSeenLocation       Location       @relation("CaseLastSeenLocation", fields: [lastSeenLocationId], references: [id])
  city                   String
  county                 String
  country                String
  physicalDescription    String
  clothingDescription    String
  distinguishingFeatures String
  summary                String         @db.Text
  emergencyContact       String
  policeReference        String?
  consentGiven           Boolean
  privacyLevel           PrivacyLevel   @default(PUBLIC)
  status                 CaseStatus     @default(ACTIVE)
  ownerId                String
  owner                  User           @relation("CaseOwner", fields: [ownerId], references: [id])
  organizationId         String?
  organization           Organization?  @relation(fields: [organizationId], references: [id])
  images                 CaseImage[]
  tips                   Tip[]
  leads                  Lead[]
  updates                CaseUpdate[]
  monitoringHits         MonitoringHit[]
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  @@index([status, privacyLevel])
  @@index([ownerId])
  @@index([lastSeenAt])
}

model CaseImage {
  id        String   @id @default(cuid())
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  url       String
  altText   String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  @@index([caseId, sortOrder])
}

model Tip {
  id              String    @id @default(cuid())
  caseId          String
  case            Case      @relation(fields: [caseId], references: [id], onDelete: Cascade)
  description     String    @db.Text
  imageUrl        String?
  seenAt          DateTime
  locationId      String?
  location        Location? @relation("TipLocation", fields: [locationId], references: [id])
  reporterName    String?
  reporterContact String?
  anonymous       Boolean   @default(false)
  confidence      Int
  status          TipStatus @default(NEW)
  submittedById   String?
  submittedBy     User?     @relation("TipReporter", fields: [submittedById], references: [id])
  similarityScore Float?
  similarityNotes String?   @db.Text
  lead            Lead?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([caseId, status])
  @@index([seenAt])
}

model Lead {
  id                String         @id @default(cuid())
  caseId            String
  case              Case           @relation(fields: [caseId], references: [id], onDelete: Cascade)
  tipId             String?        @unique
  tip               Tip?           @relation(fields: [tipId], references: [id])
  monitoringHitId   String?        @unique
  monitoringHit     MonitoringHit? @relation(fields: [monitoringHitId], references: [id])
  title             String
  snippet           String         @db.Text
  source            LeadSource
  sourceLabel       String
  confidenceScore   Float
  similarityScore   Float?
  status            LeadStatus     @default(NEW)
  occurredAt        DateTime
  handle            String?
  url               String?
  mediaThumbnailUrl String?
  locationId        String?
  location          Location?      @relation("LeadLocation", fields: [locationId], references: [id])
  notes             String?        @db.Text
  reviews           Review[]
  auditLogs         AuditLog[]
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  @@index([caseId, status])
  @@index([occurredAt])
  @@index([source])
}

model MonitoringSource {
  id        String         @id @default(cuid())
  name      String
  source    LeadSource
  enabled   Boolean        @default(true)
  config    Json?
  hits      MonitoringHit[]
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model MonitoringHit {
  id                 String            @id @default(cuid())
  caseId             String
  case               Case              @relation(fields: [caseId], references: [id], onDelete: Cascade)
  monitoringSourceId String?
  monitoringSource   MonitoringSource? @relation(fields: [monitoringSourceId], references: [id])
  source             LeadSource
  sourceLabel        String
  query              String
  textSnippet        String            @db.Text
  handle             String?
  url                String
  timestamp          DateTime
  locationId         String?
  location           Location?         @relation("MonitoringLocation", fields: [locationId], references: [id])
  mediaThumbnailUrl  String?
  confidenceScore    Float
  reviewStatus       LeadStatus        @default(NEW)
  lead               Lead?
  createdAt          DateTime          @default(now())

  @@index([caseId, timestamp])
  @@index([source, reviewStatus])
}

model Review {
  id         String         @id @default(cuid())
  leadId     String
  lead       Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User           @relation(fields: [reviewerId], references: [id])
  decision   ReviewDecision
  notes      String         @db.Text
  createdAt  DateTime       @default(now())

  @@index([leadId])
  @@index([reviewerId])
}

model AuditLog {
  id         String   @id @default(cuid())
  leadId     String?
  lead       Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  actorId    String?
  actor      User?    @relation("AuditActor", fields: [actorId], references: [id])
  entityType String
  entityId   String
  action     String
  details    Json?
  createdAt  DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorId])
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  body      String           @db.Text
  href      String?
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}

model CaseUpdate {
  id          String       @id @default(cuid())
  caseId      String
  case        Case         @relation(fields: [caseId], references: [id], onDelete: Cascade)
  title       String
  body        String       @db.Text
  visibility  PrivacyLevel @default(PUBLIC)
  createdById String?
  createdBy   User?        @relation("CaseUpdateAuthor", fields: [createdById], references: [id])
  createdAt   DateTime     @default(now())

  @@index([caseId, createdAt])
}
